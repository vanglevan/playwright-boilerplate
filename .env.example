# =============================================================================
# Playwright Boilerplate — Environment Variables
# =============================================================================
# Copy this file to .env (or .env.<env>) and fill values per environment.
# Loaded automatically by src/config/env.ts based on TEST_ENV.

# Which environment to load: dev | staging | prod | local
TEST_ENV=dev

# Application URLs
BASE_URL=https://playwright.dev
API_BASE_URL=https://jsonplaceholder.typicode.com

# Auth (use a real test account, NEVER a real production user)
TEST_USER_EMAIL=demo.user@example.com
TEST_USER_PASSWORD=Pa55w.rd
ADMIN_USER_EMAIL=admin.user@example.com
ADMIN_USER_PASSWORD=Pa55w.rd

# API auth (optional)
API_TOKEN=

# Runtime
HEADLESS=true
SLOW_MO=0
LOG_LEVEL=info
DEFAULT_TIMEOUT_MS=30000
ACTION_TIMEOUT_MS=15000
NAVIGATION_TIMEOUT_MS=30000
EXPECT_TIMEOUT_MS=10000

# CI / sharding
CI=false
WORKERS=
RETRIES=
